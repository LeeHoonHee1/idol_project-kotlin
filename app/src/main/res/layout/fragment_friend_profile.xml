<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_friend_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_friend_profile_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- 1. 친구 프로필 히어로 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_friend_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EEE5FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_friend_profile_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FRIEND PROFILE"
                    android:textColor="#8E6AD8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/iv_profile"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_circle_gray"
                    android:contentDescription="친구 프로필 이미지"
                    android:scaleType="centerCrop"
                    android:src="@drawable/person_24dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_friend_profile_label"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/iv_badge"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:contentDescription="친구 대표 뱃지"
                    android:src="@drawable/ic_badge_bronze"
                    app:layout_constraintTop_toTopOf="@id/iv_profile"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_nickname"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="닉네임"
                    android:textColor="#1F1F1F"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/iv_profile"
                    app:layout_constraintStart_toEndOf="@id/iv_profile"
                    app:layout_constraintEnd_toStartOf="@id/iv_badge" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="12dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="상태메시지 없음"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_nickname"
                    app:layout_constraintStart_toEndOf="@id/iv_profile"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_same_favorite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_same_favorite_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="같은 최애"
                    android:textColor="#7E57C2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/tv_status"
                    app:layout_constraintStart_toEndOf="@id/iv_profile" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 2. 성장 정보 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_friend_growth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_friend_profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_growth_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="친구의 팬 활동"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_growth_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="레벨과 최애 그룹 정보를 확인해요"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_level"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_activity_box"
                        android:gravity="center"
                        android:text="Lv.1"
                        android:textColor="#6F45C5"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_favorite"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_marginStart="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_activity_box"
                        android:gravity="center"
                        android:text="최애: -"
                        android:textColor="#6F45C5"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_badge_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_summary_notice"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="대표 뱃지 정보를 불러오는 중..."
                    android:textColor="#666666"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 3. 안내 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_friend_profile_notice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_friend_growth"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_friend_notice_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="함께 할 수 있는 활동"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_friend_notice_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_summary_notice"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:text="나중에 친구와 같은 최애 그룹 일정, 커뮤니티 활동, 랭킹 정보를 함께 볼 수 있게 확장할 수 있어요."
                    android:textColor="#666666"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>