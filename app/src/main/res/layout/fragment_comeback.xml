<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_comeback_schedule_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    tools:context=".Drawer.ComeBack.ComeBackFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_comeback_schedule"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="96dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 작은 제목 영역 -->
            <LinearLayout
                android:id="@+id/layout_comeback_title_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_comeback_title_simple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="컴백 일정"
                    android:textColor="#222222"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_comeback_subtitle_simple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="다가오는 컴백 일정을 확인해요"
                    android:textColor="#777777"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- 필터 탭 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_comeback_filter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                app:strokeColor="#EFE7FF"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/layout_comeback_title_bar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_comeback_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    app:tabMode="scrollable"
                    app:tabIndicatorFullWidth="false"
                    app:tabIndicatorColor="@color/lavender"
                    app:tabSelectedTextColor="@color/lavender"
                    app:tabTextColor="#888888"
                    app:tabRippleColor="#F0E8FF" />

            </com.google.android.material.card.MaterialCardView>

            <!-- 캘린더 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_comeback_calendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true"
                app:strokeColor="#EFE7FF"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/card_comeback_filter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                    android:id="@+id/calendar_comeback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="8dp"
                    app:mcv_selectionMode="single"
                    tools:ignore="MissingClass" />

            </com.google.android.material.card.MaterialCardView>

            <!-- 일정 표시 영역 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_comeback_list"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true"
                app:strokeColor="#EFE7FF"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/card_comeback_calendar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tv_selected_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_summary_notice"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingStart="14dp"
                        android:paddingTop="11dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="11dp"
                        android:text="전체 · 날짜를 선택하면 컴백 목록이 표시됩니다."
                        android:textColor="#555555"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_empty_comeback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_summary_notice"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingTop="28dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="28dp"
                        android:text="이 날짜에는 등록된 컴백 일정이 없어요"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_comeback_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingBottom="16dp"
                        tools:listitem="@layout/item_comeback" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_comeback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:contentDescription="컴백 일정 추가"
        android:src="@drawable/add_24dp"
        android:visibility="gone"
        app:backgroundTint="#8E6AD8"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>