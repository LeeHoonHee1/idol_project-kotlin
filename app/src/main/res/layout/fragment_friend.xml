<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/friend_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- 상단: 큰 제목 + 검색/친구추가 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_friend_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_friend_screen_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="친구"
            android:textColor="#222222"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_friend_actions" />

        <!-- 검색 / 친구 추가 버튼 -->
        <LinearLayout
            android:id="@+id/layout_friend_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="@id/tv_friend_screen_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_friend_screen_title"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_search_friend"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text=""
                android:textAllCaps="false"
                app:cornerRadius="18dp"
                app:icon="@drawable/search_24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="#7E57C2"
                app:strokeColor="#D6C4FF"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_friend"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text=""
                android:textAllCaps="false"
                app:cornerRadius="18dp"
                app:icon="@drawable/person_add_24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="#7E57C2"
                app:strokeColor="#D6C4FF"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- 친구 목록 섹션 제목 -->
    <TextView
        android:id="@+id/tv_friend_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="내 친구"
        android:textColor="#222222"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/card_friend_header"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 친구 수: 내 친구 옆으로 이동 -->
    <TextView
        android:id="@+id/tv_friend_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_lavender_chip"
        android:gravity="center"
        android:paddingStart="11dp"
        android:paddingTop="5dp"
        android:paddingEnd="11dp"
        android:paddingBottom="5dp"
        android:text="0명"
        android:textColor="#6F45C5"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/tv_friend_list_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_friend_list_title"
        app:layout_constraintStart_toEndOf="@id/tv_friend_list_title" />

    <TextView
        android:id="@+id/tv_friend_list_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="레벨 · 뱃지 · 최애 그룹 기준으로 보여줘요"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_friend_list_title"
        app:layout_constraintStart_toStartOf="@id/tv_friend_list_title" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_friend_filter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:chipSpacingHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_friend_list_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_friend_all"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="전체"
            android:textColor="#6F45C5"
            app:chipBackgroundColor="@color/chip_friend_filter_bg"
            app:chipStrokeColor="#D6C4FF"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_friend_same_favorite"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="같은 최애"
            android:textColor="#6F45C5"
            app:chipBackgroundColor="@color/chip_friend_filter_bg"
            app:chipStrokeColor="#D6C4FF"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_friend_level_desc"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="레벨 높은순"
            android:textColor="#6F45C5"
            app:chipBackgroundColor="@color/chip_friend_filter_bg"
            app:chipStrokeColor="#D6C4FF"
            app:chipStrokeWidth="1dp" />

    </com.google.android.material.chip.ChipGroup>


    <!-- 친구 리스트 RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_friends"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/chip_group_friend_filter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />


    <!-- 친구 없음 Empty State -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_friend_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="#EFE7FF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/chip_group_friend_filter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tv_friend_empty_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_circle_lavender"
                android:gravity="center"
                android:text="👥"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tv_friend_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="아직 친구가 없어요"
                android:textColor="#222222"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_friend_empty_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="닉네임으로 팬 친구를 찾아보세요"
                android:textColor="#888888"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_empty_find_friend"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="18dp"
                android:minWidth="120dp"
                android:text="친구 찾기"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#8E6AD8"
                app:cornerRadius="18dp"
                app:icon="@drawable/search_24dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>