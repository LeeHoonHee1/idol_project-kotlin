<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_chat_room"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="#EFE7FF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <!-- 그룹 이미지 -->
        <ImageView
            android:id="@+id/iv_group_image"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_lavender"
            android:clipToOutline="true"
            android:padding="9dp"
            android:scaleType="centerCrop"
            android:src="@drawable/person_24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 방 이름 -->
        <TextView
            android:id="@+id/tv_room_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="IVE 팬톡방"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_group_image"
            app:layout_constraintStart_toEndOf="@id/iv_group_image"
            app:layout_constraintEnd_toStartOf="@id/tv_unread_badge" />

        <!-- 마지막 메시지 -->
        <TextView
            android:id="@+id/tv_last_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="마지막 메시지가 여기에 표시됩니다."
            android:textColor="#777777"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_room_name"
            app:layout_constraintStart_toEndOf="@id/iv_group_image"
            app:layout_constraintEnd_toStartOf="@id/tv_unread_badge" />

        <!-- 팬톡 상태 칩 -->
        <TextView
            android:id="@+id/tv_room_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_summary_notice"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="실시간 팬톡"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_last_message"
            app:layout_constraintStart_toEndOf="@id/iv_group_image" />

        <!-- 안 읽은 메시지 배지 -->
        <TextView
            android:id="@+id/tv_unread_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="24dp"
            android:gravity="center"
            android:background="@drawable/bg_unread_badge"
            android:paddingStart="7dp"
            android:paddingTop="4dp"
            android:paddingEnd="7dp"
            android:paddingBottom="4dp"
            android:text="3"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_group_image"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 입장 화살표 -->
        <ImageView
            android:id="@+id/iv_room_arrow"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/chevron_right"
            app:tint="#8E6AD8"
            app:layout_constraintBottom_toBottomOf="@id/iv_group_image"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>