<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/weekly_mission_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    android:fillViewport="true"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_weekly_attendance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_weekly_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="WEEKLY QUEST"
                    android:textColor="#8E6AD8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/iv_weekly_icon"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_circle_lavender"
                    android:contentDescription="주간 출석 미션"
                    android:padding="10dp"
                    android:src="@drawable/ic_launcher_background"
                    app:layout_constraintTop_toBottomOf="@id/tv_weekly_type_label"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_weekly_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_lavender_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="0 / 7"
                    android:textColor="#6F45C5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/iv_weekly_icon"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_weekly_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="10dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="이번 주 7회 출석하기"
                    android:textColor="#222222"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/iv_weekly_icon"
                    app:layout_constraintStart_toEndOf="@id/iv_weekly_icon"
                    app:layout_constraintEnd_toStartOf="@id/tv_weekly_status" />

                <TextView
                    android:id="@+id/tv_weekly_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="5dp"
                    android:text="이번 주 출석을 7회 채우면 추가 보상을 받을 수 있어요."
                    android:textColor="#777777"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_weekly_title"
                    app:layout_constraintStart_toEndOf="@id/iv_weekly_icon"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ProgressBar
                    android:id="@+id/progress_weekly_mission"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="9dp"
                    android:layout_marginTop="16dp"
                    android:max="7"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_exp_progress"
                    app:layout_constraintTop_toBottomOf="@id/iv_weekly_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_weekly_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_friend_favorite_chip"
                    android:paddingStart="11dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="5dp"
                    android:text="주간 미션"
                    android:textColor="#6F45C5"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/progress_weekly_mission"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_weekly_reward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_reward_chip"
                    android:paddingStart="11dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="5dp"
                    android:text="EXP +50"
                    android:textColor="#2E7D32"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/tv_weekly_tag"
                    app:layout_constraintBottom_toBottomOf="@id/tv_weekly_tag"
                    app:layout_constraintStart_toEndOf="@id/tv_weekly_tag" />

                <TextView
                    android:id="@+id/tv_weekly_hint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_summary_notice"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="이번 주 7회 출석 달성 시 EXP +50"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_weekly_tag"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>