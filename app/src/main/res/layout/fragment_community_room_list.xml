<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_community_room_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- 작은 제목 영역 -->
    <LinearLayout
        android:id="@+id/layout_community_room_title_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_community_room_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="팬톡방"
            android:textColor="#222222"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_community_room_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="최애 그룹별 팬톡방에 참여해보세요"
            android:textColor="#777777"
            android:textSize="13sp" />

    </LinearLayout>


    <!-- 안내 카드 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_community_guide"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="22dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="#EFE7FF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/layout_community_room_title_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_community_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_summary_notice"
            android:paddingStart="16dp"
            android:paddingTop="13dp"
            android:paddingEnd="16dp"
            android:paddingBottom="13dp"
            android:text="내 페이지에서 설정한 최애 그룹 기준으로 팬톡방이 표시돼요."
            android:textColor="#666666"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp" />

    </com.google.android.material.card.MaterialCardView>


    <!-- 채팅방 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat_rooms"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_community_guide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>