<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_friend_request"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="#EFE7FF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_request_profile"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_circle_gray"
            android:contentDescription="요청자 프로필 이미지"
            android:scaleType="centerCrop"
            android:src="@drawable/person_24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_sender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="닉네임"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_request_profile"
            app:layout_constraintStart_toEndOf="@id/iv_request_profile"
            app:layout_constraintEnd_toStartOf="@id/iv_request_badge" />

        <TextView
            android:id="@+id/tv_request_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="상태메시지 없음"
            android:textColor="#777777"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_sender"
            app:layout_constraintStart_toEndOf="@id/iv_request_profile"
            app:layout_constraintEnd_toStartOf="@id/iv_request_badge" />

        <ImageView
            android:id="@+id/iv_request_badge"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="요청자 대표 뱃지"
            android:src="@drawable/ic_badge_bronze"
            app:layout_constraintTop_toTopOf="@id/iv_request_profile"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_request_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_lavender_chip"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="Lv.1"
            android:textColor="#6F45C5"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_request_status"
            app:layout_constraintStart_toEndOf="@id/iv_request_profile" />

        <TextView
            android:id="@+id/tv_request_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_friend_favorite_chip"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="최애: -"
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tv_request_level"
            app:layout_constraintStart_toEndOf="@id/tv_request_level" />

        <TextView
            android:id="@+id/tv_request_same_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_same_favorite_chip"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="같은 최애"
            android:textColor="#7E57C2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/iv_request_profile"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_request_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="23dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/iv_request_profile"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="76dp"
                android:layout_height="40dp"
                android:text="거절"
                android:textAllCaps="false"
                android:textColor="#777777"
                android:textSize="13sp"
                app:cornerRadius="16dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept"
                android:layout_width="76dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="수락"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#8E6AD8"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>