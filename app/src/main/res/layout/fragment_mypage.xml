<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_mypage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_mypage_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- 1. 상단 팬 프로필 히어로 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EEE5FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- 작은 상단 라벨 -->
                <TextView
                    android:id="@+id/tv_profile_section_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY FAN PROFILE"
                    android:textColor="#8E6AD8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- 프로필 편집 -->
                <ImageButton
                    android:id="@+id/iv_edit_profile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_lavender"
                    android:padding="8dp"
                    android:contentDescription="@string/edit_profile"
                    app:srcCompat="@drawable/edit_24dp"
                    app:tint="#7E57C2"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- 프로필 이미지 -->
                <ImageView
                    android:id="@+id/iv_profile_image"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_circle_gray"
                    android:contentDescription="@string/profile_image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background"
                    app:layout_constraintTop_toBottomOf="@id/tv_profile_section_label"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- 닉네임 -->
                <TextView
                    android:id="@+id/tv_nickname"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:text="닉네임"
                    android:textColor="#1F1F1F"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintTop_toTopOf="@id/iv_profile_image"
                    app:layout_constraintStart_toEndOf="@id/iv_profile_image"
                    app:layout_constraintEnd_toStartOf="@id/iv_edit_profile" />

                <!-- 상태메시지 -->
                <TextView
                    android:id="@+id/tv_status_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="8dp"
                    android:text="상태메시지를 입력해 주세요."
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    app:layout_constraintTop_toBottomOf="@id/tv_nickname"
                    app:layout_constraintStart_toEndOf="@id/iv_profile_image"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- 프로필 하단 문구 -->
                <TextView
                    android:id="@+id/tv_profile_sub_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:text="오늘도 팬 활동을 쌓아가는 중 💜"
                    android:textColor="#8E6AD8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tv_status_message"
                    app:layout_constraintStart_toEndOf="@id/iv_profile_image"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 2. 최애 그룹 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_basic_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- 최애 그룹 -->
                <LinearLayout
                    android:id="@+id/layout_fav_group_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_fav_group_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="최애 그룹"
                            android:textColor="#222222"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_fav_group_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="홈 · 일정 · 커뮤니티 기준 그룹"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_fav_group_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_lavender_chip"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="7dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="7dp"
                            android:text="설정 안 함"
                            android:textColor="#6F45C5"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_fav_group"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:minWidth="72dp"
                        android:text="선택"
                        android:textColor="#7E57C2"
                        android:textSize="13sp"
                        app:cornerRadius="18dp"
                        app:strokeColor="#BCA7F2"
                        app:strokeWidth="1dp" />

                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:background="#F0ECF8" />

                <!-- 레벨 / 뱃지 + EXP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_level_badge_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="나의 성장"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <!-- 뱃지 -->
                        <ImageView
                            android:id="@+id/iv_level_badge"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:contentDescription="@string/level_badge"
                            app:srcCompat="@drawable/ic_launcher_background"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <!-- 레벨 -->
                        <TextView
                            android:id="@+id/tv_level_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:text="Lv.1"
                            android:textColor="#1F1F1F"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="@id/iv_level_badge"
                            app:layout_constraintStart_toEndOf="@id/iv_level_badge" />

                        <TextView
                            android:id="@+id/tv_level_sub_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginTop="3dp"
                            android:text="미션을 완료하고 다음 레벨로 성장해보세요"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            app:layout_constraintTop_toBottomOf="@id/tv_level_value"
                            app:layout_constraintStart_toEndOf="@id/iv_level_badge"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <ProgressBar
                        android:id="@+id/progress_exp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="9dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="40"
                        android:progressDrawable="@drawable/bg_exp_progress" />

                    <TextView
                        android:id="@+id/tv_exp_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="EXP 40 / 100 (40%)"
                        android:textColor="#7E57C2"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 3. 내 활동 요약 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_basic_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_activity_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 활동 요약"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_activity_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="팬 활동 기록을 한눈에 확인해요"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <!-- 글 / 댓글 / 좋아요 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_post_count"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_activity_box"
                        android:gravity="center"
                        android:text="작성 글\n0개"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_comment_count"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_activity_box"
                        android:gravity="center"
                        android:text="댓글\n0개"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_like_count"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_activity_box"
                        android:gravity="center"
                        android:text="좋아요\n0개"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 출석 요약 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_total_attendance"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_attendance_box"
                        android:gravity="center"
                        android:text="총 출석: 0일"
                        android:textColor="#6F45C5"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_streak_attendance"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_marginStart="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_attendance_box"
                        android:gravity="center"
                        android:text="연속 출석: 0일"
                        android:textColor="#6F45C5"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_friend_badge_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_summary_notice"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="친구 0명 · 대표 칭호: 없음"
                    android:textColor="#666666"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. 내 뱃지 컬렉션 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_badge_collection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_activity_summary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_badge_collection_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="내 뱃지 컬렉션"
                            android:textColor="#222222"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_badge_collection_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="레벨이 오를수록 새로운 뱃지가 열려요"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_badge_collection_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_lavender_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="1 / 7"
                        android:textColor="#6F45C5"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 뱃지 가로 스크롤 -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_badge_collection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Bronze -->
                        <LinearLayout
                            android:id="@+id/layout_badge_bronze"
                            android:layout_width="74dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_bronze"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="브론즈 뱃지"
                                android:src="@drawable/ic_badge_bronze" />

                            <TextView
                                android:id="@+id/tv_badge_bronze"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Bronze"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Silver -->
                        <LinearLayout
                            android:id="@+id/layout_badge_silver"
                            android:layout_width="74dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_silver"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="실버 뱃지"
                                android:src="@drawable/ic_badge_silver" />

                            <TextView
                                android:id="@+id/tv_badge_silver"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Silver"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Gold -->
                        <LinearLayout
                            android:id="@+id/layout_badge_gold"
                            android:layout_width="74dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_gold"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="골드 뱃지"
                                android:src="@drawable/ic_badge_gold" />

                            <TextView
                                android:id="@+id/tv_badge_gold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Gold"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Platinum -->
                        <LinearLayout
                            android:id="@+id/layout_badge_platinum"
                            android:layout_width="82dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_platinum"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="플래티넘 뱃지"
                                android:src="@drawable/ic_badge_platinum" />

                            <TextView
                                android:id="@+id/tv_badge_platinum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Platinum"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Master -->
                        <LinearLayout
                            android:id="@+id/layout_badge_master"
                            android:layout_width="74dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_master"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="마스터 뱃지"
                                android:src="@drawable/ic_badge_master" />

                            <TextView
                                android:id="@+id/tv_badge_master"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Master"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Grand Master -->
                        <LinearLayout
                            android:id="@+id/layout_badge_grandmaster"
                            android:layout_width="92dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_grandmaster"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="그랜드 마스터 뱃지"
                                android:src="@drawable/ic_badge_grandmaster" />

                            <TextView
                                android:id="@+id/tv_badge_grandmaster"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Grand"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Challenger -->
                        <LinearLayout
                            android:id="@+id/layout_badge_challenger"
                            android:layout_width="92dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/iv_badge_challenger"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:contentDescription="챌린저 뱃지"
                                android:src="@drawable/ic_badge_challenger" />

                            <TextView
                                android:id="@+id/tv_badge_challenger"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Challenger"
                                android:textColor="#333333"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tv_next_badge_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_summary_notice"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="다음 뱃지까지 조금만 더 성장해보세요"
                    android:textColor="#666666"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. 내 활동 바로가기 메뉴 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mypage_menu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#EFE7FF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/card_badge_collection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_mypage_menu_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 활동 바로가기"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_mypage_menu_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="자주 쓰는 기능을 빠르게 확인해요"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <!-- 내가 쓴 글 -->
                <LinearLayout
                    android:id="@+id/layout_my_posts"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_mypage_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_lavender"
                        android:gravity="center"
                        android:text="✍"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="내가 쓴 글"
                            android:textColor="#222222"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="커뮤니티에 작성한 글을 확인해요"
                            android:textColor="#888888"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#B0A0D8"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 친구 관리 -->
                <LinearLayout
                    android:id="@+id/layout_friend_manage"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_mypage_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_lavender"
                        android:gravity="center"
                        android:text="👥"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="친구 관리"
                            android:textColor="#222222"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="친구 목록과 요청을 확인해요"
                            android:textColor="#888888"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#B0A0D8"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 고객센터 문의 내역 -->
                <LinearLayout
                    android:id="@+id/layout_my_inquiries"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_mypage_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_lavender"
                        android:gravity="center"
                        android:text="💬"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="고객센터 문의 내역"
                            android:textColor="#222222"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="내가 남긴 문의와 답변을 확인해요"
                            android:textColor="#888888"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#B0A0D8"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 알림 설정 -->
                <LinearLayout
                    android:id="@+id/layout_notification_setting"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_mypage_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_lavender"
                        android:gravity="center"
                        android:text="🔔"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="알림 설정"
                            android:textColor="#222222"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="친구 요청과 커뮤니티 알림을 관리해요"
                            android:textColor="#888888"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#B0A0D8"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>