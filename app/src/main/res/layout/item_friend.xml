<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_profile"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="#EFE7FF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="112dp"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_profile"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_circle_gray"
            android:contentDescription="친구 프로필 이미지"
            android:scaleType="centerCrop"
            android:src="@drawable/person_24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 삭제 버튼을 오른쪽 위로 고정 -->
        <ImageButton
            android:id="@+id/btn_delete_friend"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_circle_lavender"
            android:contentDescription="친구 삭제"
            android:padding="8dp"
            app:srcCompat="@drawable/outline_delete_24"
            app:tint="#8E6AD8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_nickname"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="닉네임"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_profile"
            app:layout_constraintStart_toEndOf="@id/iv_profile"
            app:layout_constraintEnd_toStartOf="@id/tv_same_favorite" />

        <TextView
            android:id="@+id/tv_same_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_same_favorite_chip"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="같은 최애"
            android:textColor="#7E57C2"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/tv_nickname"
            app:layout_constraintBottom_toBottomOf="@id/tv_nickname"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_friend" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="상태메시지"
            android:textColor="#777777"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_nickname"
            app:layout_constraintStart_toEndOf="@id/iv_profile"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_friend" />

        <!-- 대표 뱃지를 오른쪽이 아니라 레벨 칩 옆으로 이동 -->
        <ImageView
            android:id="@+id/iv_badge"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="13dp"
            android:layout_marginTop="8dp"
            android:contentDescription="친구 대표 뱃지"
            android:src="@drawable/editor_choice_24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_status"
            app:layout_constraintStart_toEndOf="@id/iv_profile" />

        <TextView
            android:id="@+id/tv_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_lavender_chip"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="Lv.1"
            android:textColor="#6F45C5"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_badge"
            app:layout_constraintBottom_toBottomOf="@id/iv_badge"
            app:layout_constraintStart_toEndOf="@id/iv_badge" />

        <TextView
            android:id="@+id/tv_favorite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_friend_favorite_chip"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="최애: -"
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tv_level"
            app:layout_constraintBottom_toBottomOf="@id/tv_level"
            app:layout_constraintStart_toEndOf="@id/tv_level"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>