<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- 안쪽 색 (연한 회색) -->
    <solid android:color="#DDDDDD" />

    <!-- 살짝 그림자 느낌 주고 싶으면 스트로크도 가능 -->
    <stroke
        android:width="1dp"
        android:color="#CCCCCC" />

    <!-- 전체 크기는 ImageView에서 정하니까 여기선 패딩만 살짝 -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />

</shape>
