<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 안쪽 배경 색 (연보라 느낌) -->
    <solid android:color="#F3E8FF" />

    <!-- 모서리 둥글게 (칩 느낌) -->
    <corners android:radius="16dp" />

    <!-- 안쪽 여백 (텍스트랑 테두리 붙지 않게) -->
    <padding
        android:left="6dp"
        android:top="2dp"
        android:right="6dp"
        android:bottom="2dp" />

    <!-- 테두리 살짝 -->
    <stroke
        android:width="1dp"
        android:color="#B39DDB" />
</shape>
